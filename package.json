{
  "name": "@cg3/equip",
  "version": "0.17.7",
  "description": "Augment your AI agents — MCP servers, behavioral rules, and skills across every platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "equip": "bin/equip.js",
    "unequip": "bin/unequip.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "bin/",
    "demo/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test test/equip.test.js test/observability.test.js test/registry.test.js test/auth.test.js test/docs.test.js test/augment-defs.test.js test/platform-state.test.js test/snapshots.test.js test/security.test.js test/content-hash.test.js test/cli.test.js",
    "test:docker:acceptance": "node scripts/ci/run-docker-acceptance.mjs",
    "test:docker:acceptance:internal": "npm run build && node --test test/docker/acceptance.test.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ai",
    "agent",
    "augment",
    "setup",
    "claude",
    "cursor",
    "windsurf",
    "vscode",
    "cline",
    "roo-code",
    "codex",
    "gemini"
  ],
  "author": "Charles Mulic",
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/CharlesMulic/equip"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
