      "installName": "mcp-tandem-docs",
      "serverName": "ac.tandem/docs-mcp",
      "version": "latest",
      "target": {
        "kind": "remote",
        "transport": "streamable-http"
      },
      "expected": {
        "support": "install"
      }
    },
