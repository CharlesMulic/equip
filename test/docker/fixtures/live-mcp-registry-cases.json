{
  "schemaVersion": 1,
  "registryBaseUrl": "https://registry.modelcontextprotocol.io",
  "description": "Live MCP registry install spike cases. These are intentionally retained so the Docker spike can be rerun against the same representative server set.",
  "platforms": [
    "claude-code",
    "codex",
    "cursor",
    "vscode",
    "roo-code"
  ],
  "cases": [
    {
      "id": "remote-streamable-public",
      "installName": "mcp-tandem-docs",
      "serverName": "ac.tandem/docs-mcp",
      "version": "latest",
      "target": {
        "kind": "remote",
        "transport": "streamable-http"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "remote-streamable-authorization",
      "installName": "mcp-github-remote",
      "serverName": "io.github.github/github-mcp-server",
      "version": "latest",
      "target": {
        "kind": "remote",
        "transport": "streamable-http"
      },
      "credential": {
        "apiKey": "test-github-token"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "stdio-npm-public",
      "installName": "mcp-chrome-devtools",
      "serverName": "io.github.ChromeDevTools/chrome-devtools-mcp",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "npm",
        "transport": "stdio"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "stdio-npm-secret-env",
      "installName": "mcp-context7",
      "serverName": "io.github.upstash/context7",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "npm",
        "transport": "stdio"
      },
      "credential": {
        "apiKey": "test-context7-token"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "stdio-pypi-public",
      "installName": "mcp-mcparmory-github-pypi",
      "serverName": "com.mcparmory/github",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "pypi",
        "transport": "stdio"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "stdio-oci-secret-env",
      "installName": "mcp-github-oci",
      "serverName": "io.github.github/github-mcp-server",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "oci",
        "transport": "stdio"
      },
      "credential": {
        "apiKey": "test-github-token"
      },
      "expected": {
        "support": "install"
      }
    },
    {
      "id": "stdio-npm-required-non-secret-env",
      "installName": "mcp-filesystem-required-env",
      "serverName": "io.github.Digital-Defiance/mcp-filesystem",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "npm",
        "transport": "stdio"
      },
      "expected": {
        "support": "unsupported",
        "reason": "required-env-without-auth-value"
      }
    },
    {
      "id": "remote-sse",
      "installName": "mcp-waystation-postgres-sse",
      "serverName": "ai.waystation/postgres",
      "version": "latest",
      "target": {
        "kind": "remote",
        "transport": "sse"
      },
      "expected": {
        "support": "unsupported",
        "reason": "remote-sse"
      }
    },
    {
      "id": "package-streamable-http",
      "installName": "mcp-hapi-package-http",
      "serverName": "ai.com.mcp/hapi-mcp",
      "version": "latest",
      "target": {
        "kind": "package",
        "registryType": "oci",
        "transport": "streamable-http"
      },
      "expected": {
        "support": "unsupported",
        "reason": "package-non-stdio-transport"
      }
    }
  ]
}
