{
  "name": "@cg3/equip",
  "version": "0.9.3",
  "description": "Universal MCP + behavioral rules installer for AI coding agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "equip": "bin/equip.js",
    "unequip": "bin/unequip.js"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "require": "./dist/index.js" },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "bin/",
    "demo/",
    "registry.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test test/equip.test.js test/docs.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ai",
    "agent",
    "setup",
    "claude",
    "cursor",
    "windsurf",
    "vscode",
    "cline",
    "roo-code",
    "codex",
    "gemini"
  ],
  "author": "Charles Mulic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CharlesMulic/equip"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
