FROM ghcr.io/astral-sh/uv:0.9.13 AS uv
FROM node:22-bookworm

WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-setuptools python3-wheel \
  && rm -rf /var/lib/apt/lists/*

COPY --from=uv /uv /uvx /usr/local/bin/

COPY package.json package-lock.json tsconfig.json ./
COPY src ./src
COPY test/docker/mcp-initialize-smoke.test.mjs ./test/docker/mcp-initialize-smoke.test.mjs
COPY test/docker/fixtures/mcp-initialize-cases.json ./test/docker/fixtures/mcp-initialize-cases.json
COPY test/docker/fixtures/mcp-initialize ./test/docker/fixtures/mcp-initialize

RUN npm ci
RUN npm run build

RUN useradd --create-home --uid 10001 equip \
  && mkdir -p /opt/equip-mcp-smoke/npm \
  && mkdir -p /opt/equip-mcp-smoke/pypi \
  && chmod 755 /workspace/test/docker/fixtures/mcp-initialize/npm-stdio-server/server.mjs \
  && npm pack /workspace/test/docker/fixtures/mcp-initialize/npm-stdio-server --pack-destination /opt/equip-mcp-smoke/npm --ignore-scripts \
  && cd /workspace/test/docker/fixtures/mcp-initialize/pypi-stdio-server \
  && python3 setup.py bdist_wheel --dist-dir /opt/equip-mcp-smoke/pypi \
  && chown -R 10001:10001 /workspace /opt/equip-mcp-smoke

USER 10001:10001

ENV HOME=/home/equip \
  NO_COLOR=1 \
  FORCE_COLOR=0

CMD ["npm", "run", "test:docker:mcp-initialize-smoke:internal"]
